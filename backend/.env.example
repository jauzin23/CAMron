# Required environment variables for the backend server.
# Copy this file to .env and fill in the values.
# Not needed when using Docker (set vars in docker-compose.yml).

# Port the Node.js server listens on
PORT=3000

# Bearer token shared with the camera firmware (ESP32 device authentication).
# Must exactly match CAMERA_BEARER_TOKEN in sketch_camron/config.h
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CAMERA_BEARER_TOKEN=REPLACE_WITH_YOUR_CAMERA_TOKEN

# PIN for user authentication on the dashboard (4-6 numeric digits)
APP_PIN=1234

# Secret used to sign JWT session tokens (keep this long and random!)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET

# JWT token expiry duration (e.g. 15m, 1h, 30m)
JWT_EXPIRY=15m

# Path to the arduino-cli binary for firmware compilation
ARDUINO_CLI_PATH=/path/to/arduino-cli