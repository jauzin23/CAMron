# Public port for the Nginx gateway (accessible by browsers and ESP32 cameras in Docker setup)
FRONTEND_PORT=3005

# Internal port for the local Express backend (used only for local non-Docker development)
BACKEND_PORT=3000


# Local LAN IP of the host machine.
# Replace with your server's actual local IP address so the ESP32 camera firmware points to the correct destination.
HOST_IP=192.168.1.100

# Local backend API URL accessed by the frontend browser bundle during local non-Docker development
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000

# Security PIN to access the dashboard
APP_PIN=1234

# Secret key used for signing JWT tokens (generate a long random string for production)
JWT_SECRET=secret_default_key_change_me

# JWT token expiration time (e.g., 15m, 1h, 1d)
JWT_EXPIRY=15m
